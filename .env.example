# Muffin Pan Recipes - Environment Variables Template
#
# 🛡️ SECURITY POLICY:
# All secrets are managed via Doppler (project: muffinpanrecipes).
# DO NOT use .env files for secrets in this project.
#
# Locally: `doppler run -- uv run python -m backend.admin.app`
# On Vercel: Secrets are injected automatically via Doppler integration.
#
# Doppler quickstart:
#   brew install dopplerhq/cli/doppler
#   doppler login
#   doppler setup              # select muffinpanrecipes / dev
#   doppler run -- <command>   # injects all secrets as env vars

# --- Local Development ---
# LOCAL_DEV=true              # Bypasses Google OAuth; returns dummy session. NEVER set in production.

# --- AI Model Keys ---
OPENAI_API_KEY=               # [REQUIRED] OpenAI API key (dialogue, recipes, vision eval)
ANTHROPIC_API_KEY=            # [REQUIRED] Anthropic API key (judge pipeline, fallback provider)
STABILITY_API_KEY=            # [REQUIRED] Stability AI image generation
GEMINI_API_KEY=               # [OPTIONAL] Google Gemini (reserved for #5034)

# --- Model Selection ---
# Format: "provider/model" e.g. "openai/gpt-5.1", "anthropic/claude-haiku-4-5"
# NOTE: DIALOGUE_MODEL and RECIPE_MODEL have NO hardcoded fallbacks and will raise if missing.
DIALOGUE_MODEL=               # [REQUIRED] Weekly dialogue generation (e.g. anthropic/claude-haiku-4-5)
RECIPE_MODEL=                 # [REQUIRED] Baker recipe generation (e.g. openai/gpt-5.1)
JUDGE_MODEL=                  # [OPTIONAL] Opus judge pipeline (default: anthropic/claude-sonnet-4-6)
VISION_EVAL_MODEL=            # [OPTIONAL] Art Director image evaluation (default: openai/gpt-5-mini)

# --- Authentication ---
GOOGLE_CLIENT_ID=             # Google OAuth client ID
GOOGLE_CLIENT_SECRET=         # Google OAuth client secret
GOOGLE_REDIRECT_URI=          # OAuth callback URL (e.g. https://muffinpanrecipes.com/auth/callback)
GOOGLE_AUTHORIZED_EMAILS=     # Comma-separated allowed admin emails
JWT_SECRET=                   # Session token signing key (generate: openssl rand -hex 32)

# --- Vercel / Infrastructure ---
CRON_SECRET=                  # Vercel cron auth token (auto-generated by Vercel)
BLOB_READ_WRITE_TOKEN=        # Vercel Blob storage token (episode persistence across Lambda invocations)
MUFFINPAN_ADMIN_BASE_URL=     # Admin dashboard URL for Discord links (e.g. https://muffinpanrecipes.com)

# --- Notifications ---
MUFFINPAN_DISCORD_WEBHOOK=    # Discord webhook URL for pipeline notifications

# --- Publishing Schedule (DST-aware local market clock) ---
MUFFINPAN_PUBLISH_TIMEZONE=America/Los_Angeles
MUFFINPAN_PUBLISH_WEEKDAY=6   # 0=Mon ... 6=Sun
MUFFINPAN_PUBLISH_HOUR=17
MUFFINPAN_PUBLISH_MINUTE=0
