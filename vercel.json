{
    "version": 2,
    "buildCommand": "npm run build:css",
    "builds": [
        {
            "src": "backend/admin/app.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "maxDuration": 300
            }
        },
        {
            "src": "src/**",
            "use": "@vercel/static"
        },
        {
            "src": "backend/admin/static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "headers": {
                "Location": "https://muffinpanrecipes.com/$1"
            },
            "has": [
                {
                    "type": "host",
                    "value": "www.muffinpanrecipes.com"
                }
            ],
            "status": 301
        },
        {
            "src": "/api/(.*)",
            "dest": "backend/admin/app.py"
        },
        {
            "src": "/admin/static/(.*)",
            "dest": "/backend/admin/static/$1"
        },
        {
            "src": "/admin/(.*)",
            "dest": "backend/admin/app.py"
        },
        {
            "src": "/auth/(.*)",
            "dest": "backend/admin/app.py"
        },
        {
            "src": "/health(/.*)?",
            "dest": "backend/admin/app.py"
        },
        {
            "src": "/recipes/([^/]+)$",
            "dest": "/src/recipes/$1/index.html"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/src/assets/$1"
        },
        {
            "src": "/sitemap\\.xml",
            "dest": "/src/sitemap.xml"
        },
        {
            "src": "/robots\\.txt",
            "dest": "/src/robots.txt"
        },
        {
            "src": "/recipes\\.json",
            "dest": "/src/recipes.json"
        },
        {
            "src": "/episodes/([^/]+)/?$",
            "dest": "/src/episodes/$1/index.html"
        },
        {
            "src": "/test/?$",
            "dest": "/src/test/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/src/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/monday",
            "schedule": "30 14 * * 1"
        },
        {
            "path": "/api/cron/tuesday",
            "schedule": "30 14 * * 2"
        },
        {
            "path": "/api/cron/wednesday",
            "schedule": "30 14 * * 3"
        },
        {
            "path": "/api/cron/thursday",
            "schedule": "30 14 * * 4"
        },
        {
            "path": "/api/cron/friday",
            "schedule": "30 14 * * 5"
        },
        {
            "path": "/api/cron/saturday",
            "schedule": "30 14 * * 6"
        },
        {
            "path": "/api/cron/sunday",
            "schedule": "0 0 * * 0"
        }
    ],
    "env": {
        "PYTHONPATH": "."
    }
}