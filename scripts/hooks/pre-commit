#!/usr/bin/env bash
# pre-commit hook: Block unauthorized writes to src/recipes/ and src/recipes.json
#
# These paths are managed exclusively by the PublishingPipeline.
# Commits that touch them must include [publish] in the commit message.
#
# Policy: --no-verify bypasses are FORBIDDEN. Fix the root cause instead.
# See AGENTS.md § Publishing Protocol for the approved publishing flow.

set -euo pipefail

PROTECTED_PATTERNS=(
    "^src/recipes/"
    "^src/recipes\.json$"
)

changed_files=$(git diff --cached --name-only)

for pattern in "${PROTECTED_PATTERNS[@]}"; do
    if echo "$changed_files" | grep -qE "$pattern"; then
        # Allow if commit message contains [publish] or starts with publish:
        # Read commit message from COMMIT_EDITMSG if available (interactive),
        # or skip message check and block (for non-interactive/scripted commits).
        msg_file="${GIT_DIR:-$(git rev-parse --git-dir)}/COMMIT_EDITMSG"
        if [[ -f "$msg_file" ]]; then
            commit_msg=$(cat "$msg_file")
            if echo "$commit_msg" | grep -qiE '(\[publish\]|^publish:)'; then
                echo "✅ pre-commit: publish marker found — allowing src/recipes/ change."
                exit 0
            fi
        fi

        echo ""
        echo "🛑 BLOCKED: Direct write to protected publishing path."
        echo ""
        echo "   Files affected:"
        echo "$changed_files" | grep -E "$pattern" | sed 's/^/   - /'
        echo ""
        echo "   src/recipes/ and src/recipes.json are managed ONLY by the"
        echo "   PublishingPipeline (backend/publishing/pipeline.py)."
        echo ""
        echo "   To commit a legitimate publish, use the admin dashboard or"
        echo "   include [publish] in your commit message:"
        echo "     git commit -m 'publish: Recipe name [publish]'"
        echo ""
        echo "   NOT RECOMMENDED: git commit --no-verify (bypasses safety)"
        echo ""
        exit 1
    fi
done

exit 0
