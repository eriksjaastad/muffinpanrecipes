#!/usr/bin/env bash
# pre-commit hook: Detect writes to protected publishing paths.
#
# These paths are managed exclusively by the PublishingPipeline.
# The commit-msg hook will enforce the 'publish:' marker requirement.
#
# NOTE: COMMIT_EDITMSG is not available at pre-commit time (only at commit-msg).
# This hook only detects protected paths and warns; commit-msg enforces the marker.
#
# Policy: --no-verify bypasses are FORBIDDEN. Fix the root cause instead.
# See AGENTS.md § Publishing Protocol for the approved publishing flow.

set -euo pipefail

PROTECTED_PATTERNS=(
    "^src/recipes/"
    "^src/recipes\.json$"
)

changed_files=$(git diff --cached --name-only)

for pattern in "${PROTECTED_PATTERNS[@]}"; do
    if echo "$changed_files" | grep -qE "$pattern"; then
        echo ""
        echo "⚠️  WARNING: Commit touches protected publishing paths."
        echo ""
        echo "   Files affected:"
        echo "$changed_files" | grep -E "$pattern" | sed 's/^/   - /'
        echo ""
        echo "   src/recipes/ and src/recipes.json are managed ONLY by the"
        echo "   PublishingPipeline (backend/publishing/pipeline.py)."
        echo ""
        echo "   Your commit message MUST include 'publish:' or '[publish]'"
        echo "     git commit -m 'publish: Recipe name'"
        echo "     git commit -m 'Recipe name [publish]'"
        echo ""
        # Pre-commit only warns; commit-msg hook will enforce the marker
        exit 0
    fi
done

exit 0
